// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model SetupOption {
  id   Int     @id @default(auto()) @map("_id") @db.UnsignedInt
  name String  @unique
}

model ErrorOption {
  id   Int     @id @default(auto()) @map("_id") @db.UnsignedInt
  name String  @unique
}

model ExitOption {
  id   Int     @id @default(auto()) @map("_id") @db.UnsignedInt
  name String  @unique
}

model SymbolOption {
  id   Int     @id @default(auto()) @map("_id") @db.UnsignedInt
  name String  @unique
}

model Trade {
  id           String   @id @default(uuid())
  date         DateTime
  setup        String
  type         String
  exitReason   String
  direction    String   // "Long" or "Short"
  positionSize Float
  entryPrice   Float
  stopLoss     Float?
  takeProfit   Float?
  exitPrice1   Float
  exitPrice2   Float?
  pnl          Float
  rr           Float?
  status       String   // "win", "lose", "BE"
  remarks      String?
  notes        String?
  errorReason  String?
  symbol       String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  screenshots  TradeScreenshot[]
}

model TradeScreenshot {
  id        String   @id @default(uuid())
  tradeId   String
  filename  String
  path      String
  createdAt DateTime @default(now())
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}
